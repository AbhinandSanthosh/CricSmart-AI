# CricEye AI - Environment Variables
# Copy this file to .env.local and fill in your keys

# Turso Database (free at https://turso.tech)
# Leave empty to use local SQLite file for development
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# CricAPI for live match data (free at https://cricapi.com)
# CRICAPI_KEY=your-key-here

# Anthropic API for AI Coach
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API for AI Coach fallback (free at https://openrouter.ai/keys)
# OPENROUTER_API_KEY=your-key-here
# OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# Ball Tracking ML Service URL
# Set to your deployed ML service (e.g. Render: https://cricsmart-ml.onrender.com)
# Leave empty for http://localhost:8000 during local development
# NEXT_PUBLIC_ML_SERVICE_URL=https://cricsmart-ml.onrender.com

# Site URL (set to your Vercel domain in production)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
